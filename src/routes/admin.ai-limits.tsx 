import { createFileRoute, Link } from "@tanstack/react-router";
import { useEffect, useState } from "react";
import { useServerFn } from "@tanstack/react-start";
import { useMe } from "@/hooks/use-me";
import { listPlans, adminUpdatePlanPrices } from "@/lib/subscription.functions";
import { AppNav } from "@/components/AppNav";
import { DuoButton } from "@/components/DuoButton";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { 
  Loader2, 
  Save, 
  Sparkles,
  Zap,
  Users,
  BarChart3
} from "lucide-react";

export const Route = createFileRoute("/admin/ai-limits")({
  component: AdminAILimits,
});

function AdminAILimits() {
  const { me, loading } = useMe();
  const listPlansFn = useServerFn(listPlans);
  const updatePricesFn = useServerFn(adminUpdatePlanPrices);
  
  const [plans, setPlans] = useState<any[]>([]);
  const [drafts, setDrafts] = useState<Record<string, { 
    ai_qcm_per_day: number, 
    hearts_max: number,
    features: string[]
  }>>({});
  const [busy, setBusy] = useState(false);
  const [msg, setMsg] = useState<string | null>(null);

  const refresh = async () => {
    const data = await listPlansFn();
    setPlans(data);
    const newDrafts: Record<string, any> = {};
    data.forEach((plan: any) => {
      newDrafts[plan.id] = {
        ai_qcm_per_day: plan.ai_qcm_per_day || 10,
        hearts_max: plan.hearts_max || 5,
        features: plan.features || [],
      };
    });
    setDrafts(newDrafts);
  };

  useEffect(() => {
    if (me?.isAdmin) refresh();
  }, [me]);

  const handleSave = async () => {
    setBusy(true);
    try {
      const updates = Object.entries(drafts).map(([id, data]) => ({
        id,
        ai_qcm_per_day: data.ai_qcm_per_day,
        hearts_max: data.hearts_max,
      }));
      await updatePricesFn({ data: { updates } });
      await refresh();
      setMsg("Limites mises à jour !");
    } catch (e) {
      setMsg("Erreur: " + (e as Error).message);
    } finally {
      setBusy(false);
    }
  };

  if (loading || !me) return <div className="flex min-h-screen items-center justify-center"><Loader2 className="h-6 w-6 animate-spin" /></div>;
  if (!me.isAdmin) return <div className="p-6">Accès refusé.</div>;

  return (
    <div className="min-h-screen">
      <AppNav isAdmin />
      <main className="container mx-auto p-6 space-y-6 max-w-4xl">
        <div>
          <Link to="/admin" className="text-sm text-muted-foreground hover:text-foreground">← Admin</Link>
          <h1 className="text-3xl font-extrabold mt-2">🤖 Limites IA</h1>
          <p className="text-sm text-muted-foreground">Gérer les limites d'utilisation de l'IA par abonnement</p>
        </div>

        <Card>
          <CardHeader>
            <CardTitle>Configuration des limites</CardTitle>
          </CardHeader>
          <CardContent className="space-y-6">
            {plans.map((plan) => (
              <div key={plan.id} className="border-2 rounded-xl p-4 space-y-3">
                <div className="flex items-center justify-between">
                  <h3 className="font-extrabold text-lg">{plan.label}</h3>
                  <span className="text-sm text-muted-foreground">{plan.price_mad} MAD</span>
                </div>
                
                <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <Label className="text-xs flex items-center gap-1">
                      <Sparkles className="h-3 w-3" /> QCM IA par jour
                    </Label>
                    <Input 
                      type="number"
                      min={0}
                      max={99999}
                      value={drafts[plan.id]?.ai_qcm_per_day ?? 10}
                      onChange={(e) => setDrafts({
                        ...drafts,
                        [plan.id]: { 
                          ...drafts[plan.id], 
                          ai_qcm_per_day: Number(e.target.value) 
                        }
                      })}
                    />
                    <p className="text-xs text-muted-foreground mt-1">
                      {drafts[plan.id]?.ai_qcm_per_day >= 9999 ? "♾️ Illimité" : `${drafts[plan.id]?.ai_qcm_per_day || 10} par jour`}
                    </p>
                  </div>
                  <div>
                    <Label className="text-xs flex items-center gap-1">
                      <Zap className="h-3 w-3" /> Cœurs max
                    </Label>
                    <Input 
                      type="number"
                      min={1}
                      max={999}
                      value={drafts[plan.id]?.hearts_max ?? 5}
                      onChange={(e) => setDrafts({
                        ...drafts,
                        [plan.id]: { 
                          ...drafts[plan.id], 
                          hearts_max: Number(e.target.value) 
                        }
                      })}
                    />
                    <p className="text-xs text-muted-foreground mt-1">
                      {drafts[plan.id]?.hearts_max || 5} cœurs maximum
                    </p>
                  </div>
                </div>

                <div className="bg-muted/30 rounded-lg p-3">
                  <p className="text-xs font-bold text-muted-foreground">Fonctionnalités actuelles:</p>
                  <div className="flex flex-wrap gap-1 mt-1">
                    {(plan.features || []).map((f: string, i: number) => (
                      <span key={i} className="text-xs bg-primary/10 text-primary px-2 py-0.5 rounded">
                        {f}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            ))}

            <DuoButton 
              variant="primary" 
              disabled={busy}
              onClick={handleSave}
              className="w-full"
            >
              {busy ? <Loader2 className="h-4 w-4 animate-spin" /> : <Save className="h-4 w-4" />}
              Enregistrer toutes les limites
            </DuoButton>

            {msg && <p className="text-sm font-bold text-center">{msg}</p>}
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle>📊 Utilisation IA en temps réel</CardTitle>
          </CardHeader>
          <CardContent>
            <div className="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <div className="border rounded-xl p-3 text-center">
                <p className="text-xs text-muted-foreground">Total requêtes aujourd'hui</p>
                <p className="text-2xl font-extrabold">—</p>
              </div>
              <div className="border rounded-xl p-3 text-center">
                <p className="text-xs text-muted-foreground">Utilisateurs actifs</p>
                <p className="text-2xl font-extrabold">—</p>
              </div>
              <div className="border rounded-xl p-3 text-center">
                <p className="text-xs text-muted-foreground">Token utilisé</p>
                <p className="text-2xl font-extrabold">—</p>
              </div>
            </div>
            <p className="text-xs text-muted-foreground text-center mt-4">
              Les statistiques d'utilisation seront disponibles après quelques appels IA
            </p>
          </CardContent>
        </Card>
      </main>
    </div>
  );
}