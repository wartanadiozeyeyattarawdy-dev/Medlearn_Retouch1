import { createFileRoute, Link } from "@tanstack/react-router";
import { useEffect, useState } from "react";
import { useServerFn } from "@tanstack/react-start";
import { useMe } from "@/hooks/use-me";
import { useStats } from "@/hooks/use-stats";
import { listStudentServices } from "@/lib/social.functions";
import { AppNav } from "@/components/AppNav";
import { DuoButton } from "@/components/DuoButton";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Tabs, TabsList, TabsTrigger, TabsContent } from "@/components/ui/tabs";
import { Loader2, BookOpen, FileText, GraduationCap, Star, Plus, Eye } from "lucide-react";

export const Route = createFileRoute("/services/")({
  component: ServicesPage,
});

function ServicesPage() {
  const { me, loading } = useMe();
  const { stats } = useStats();
  const listFn = useServerFn(listStudentServices);
  const [services, setServices] = useState<any[]>([]);
  const [filter, setFilter] = useState<string>("all");
  const [isLoading, setIsLoading] = useState(true);

  useEffect(() => {
    const load = async () => {
      const data = await listFn();
      setServices(data);
      setIsLoading(false);
    };
    load();
  }, [listFn]);

  if (loading || isLoading) {
    return <div className="flex min-h-screen items-center justify-center"><Loader2 className="h-8 w-8 animate-spin text-primary" /></div>;
  }

  const typeIcons: Record<string, any> = {
    summary: FileText,
    tutoring: GraduationCap,
    notes: BookOpen,
    flashcards: BookOpen,
  };

  const typeLabels: Record<string, string> = {
    summary: "Résumé",
    tutoring: "Tutorat",
    notes: "Notes",
    flashcards: "Flashcards",
  };

  const filteredServices = filter === "all" 
    ? services 
    : services.filter(s => s.type === filter);

  return (
    <div className="min-h-screen">
      <AppNav isAdmin={me?.isAdmin || false} stats={stats} />
      <main className="container mx-auto p-4 sm:p-6 space-y-6 max-w-6xl">
        <div className="flex justify-between items-center">
          <div>
            <h1 className="text-3xl font-extrabold">📚 Services étudiants</h1>
            <p className="text-muted-foreground">Découvre les résumés, notes et tutorats créés par la communauté</p>
          </div>
          <Link to="/services/new">
            <DuoButton variant="primary">
              <Plus className="h-4 w-4" /> Publier un service
            </DuoButton>
          </Link>
        </div>

        <Tabs value={filter} onValueChange={setFilter}>
          <TabsList className="grid grid-cols-5 gap-1 h-auto p-1 rounded-xl bg-muted">
            <TabsTrigger value="all" className="rounded-lg font-bold">Tous</TabsTrigger>
            <TabsTrigger value="summary" className="rounded-lg font-bold">📄 Résumés</TabsTrigger>
            <TabsTrigger value="notes" className="rounded-lg font-bold">📝 Notes</TabsTrigger>
            <TabsTrigger value="flashcards" className="rounded-lg font-bold">🃏 Flashcards</TabsTrigger>
            <TabsTrigger value="tutoring" className="rounded-lg font-bold">🎓 Tutorat</TabsTrigger>
          </TabsList>

          <TabsContent value={filter} className="mt-5">
            {filteredServices.length === 0 ? (
              <Card>
                <CardContent className="p-8 text-center">
                  <p className="text-muted-foreground">Aucun service disponible pour le moment</p>
                  <Link to="/services/new" className="text-primary font-bold hover:underline">
                    Sois le premier à publier !
                  </Link>
                </CardContent>
              </Card>
            ) : (
              <div className="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {filteredServices.map((service) => {
                  const Icon = typeIcons[service.type] || FileText;
                  return (
                    <Link key={service.id} to="/services/$serviceId" params={{ serviceId: service.id }}>
                      <Card className="hover:border-primary transition-all cursor-pointer h-full">
                        <CardHeader>
                          <div className="flex items-start justify-between">
                            <div className="flex items-center gap-2">
                              <Icon className="h-5 w-5 text-primary" />
                              <span className="text-xs font-bold text-muted-foreground">
                                {typeLabels[service.type] || service.type}
                              </span>
                            </div>
                            {service.is_free ? (
                              <span className="text-xs bg-success/15 text-success px-2 py-0.5 rounded font-bold">Gratuit</span>
                            ) : (
                              <span className="text-xs bg-primary/15 text-primary px-2 py-0.5 rounded font-bold">{service.price} MAD</span>
                            )}
                          </div>
                          <CardTitle className="text-lg line-clamp-2">{service.title}</CardTitle>
                        </CardHeader>
                        <CardContent>
                          <p className="text-sm text-muted-foreground line-clamp-3 mb-3">
                            {service.description || "Aucune description"}
                          </p>
                          <div className="flex items-center justify-between text-xs text-muted-foreground">
                            <span className="flex items-center gap-1">
                              {service.profiles?.avatar_emoji || "👤"} {service.profiles?.full_name || "Anonyme"}
                            </span>
                            <span className="flex items-center gap-1">
                              <Eye className="h-3 w-3" /> {service.views_count || 0}
                            </span>
                          </div>
                          {service.tags?.length > 0 && (
                            <div className="flex flex-wrap gap-1 mt-2">
                              {service.tags.slice(0, 3).map((tag: string) => (
                                <span key={tag} className="text-xs bg-muted px-2 py-0.5 rounded">
                                  #{tag}
                                </span>
                              ))}
                            </div>
                          )}
                        </CardContent>
                      </Card>
                    </Link>
                  );
                })}
              </div>
            )}
          </TabsContent>
        </Tabs>
      </main>
    </div>
  );
}